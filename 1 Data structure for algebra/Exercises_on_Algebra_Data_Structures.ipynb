      "source": [
        "import numpy as np\n",
        "z = np.array([[32], [5], [-7], [-15]]) #inisialisasi vektor z\n",
        "print(z) #tampilkan vektor z\n",
        "z_t = z.T #tranpose vektor z dan masukkan dalam z_t\n",
        "print(z_t) #tampilkan z_t"
      ]
